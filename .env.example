# ================================================
# EasyDeploy PaaS - Environment Configuration
# ================================================
# Copy this file to .env and edit the values

# Application
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Laravel App Key (generate with: php artisan key:generate)
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_ARTISAN

# Database
DB_PASSWORD=easydeploy_dev
DB_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Orchestrator
ORCHESTRATOR_PORT=8080
API_KEY=easydeploy_api_key_dev

# Agent
AGENT_SERVER_ID=dev-server-01
AGENT_SERVER_NAME=Development Server
AGENT_GRPC_PORT=9090
AGENT_HTTP_PORT=9091

# Docker Registry
DOCKER_REGISTRY=localhost:5000
REGISTRY_PORT=5000

# Panel
PANEL_PORT=8000

# Traefik
TRAEFIK_DASHBOARD_PORT=8081
TRAEFIK_LOG_LEVEL=INFO

# ACME / Let's Encrypt (disabled for development)
ACME_ENABLED=false
ACME_EMAIL=admin@easyti.cloud
ACME_STAGING=true

# Logging
LOG_LEVEL=debug

# ================================================
# Production-only settings (docker-compose.prod.yml)
# ================================================
# DOMAIN=easyti.cloud
# VERSION=latest
# TRAEFIK_AUTH=user:$$apr1$$hashed_password
# ORCHESTRATOR_API_KEY=change_me_to_a_secure_key
