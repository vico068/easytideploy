FROM node:18-alpine AS base

WORKDIR /app

# Increase Node.js memory limit to avoid OOM during npm install
ENV NODE_OPTIONS="--max-old-space-size=512" \
    NPM_CONFIG_AUDIT="false" \
    NPM_CONFIG_FUND="false" \
    NPM_CONFIG_UPDATE_NOTIFIER="false" \
    npm_config_jobs="1" \
    NPM_CONFIG_MAX_CONCURRENT=1

# Install dependencies with reduced concurrency to avoid OOM
COPY package*.json yarn.lock* pnpm-lock.yaml* ./
RUN if [ -f yarn.lock ]; then yarn install --frozen-lockfile --network-concurrency 1; \
    elif [ -f pnpm-lock.yaml ]; then npm install -g pnpm && pnpm install --frozen-lockfile; \
    else npm ci --maxsockets 1 2>/dev/null || npm install --maxsockets 1; fi

# Copy source code
COPY . .

# Build if command is provided
ARG BUILD_COMMAND=""
RUN if [ -n "$BUILD_COMMAND" ]; then sh -c "$BUILD_COMMAND"; fi

# Expose port
EXPOSE ${PORT:-3000}

# Start command
ARG START_COMMAND="npm start"
CMD sh -c "$START_COMMAND"
